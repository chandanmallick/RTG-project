# Backend runtime configuration
# Copy values into your server/service environment.

APP_BACKEND_TITLE=ASTRO Backend

# Mongo can be IP based internally or a DNS alias, for example:
# mongodb://mongo.internal.erldc.in:27017/
MONGO_URI=mongodb://10.3.230.60:27017/
MONGO_DB_NAME=rtg_db
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

# Set false for local UI/API work when MongoDB or internal network is unavailable.
RUN_SCHEDULER=true

# For same-domain deployment through reverse proxy, keep only your public URL.
# For local development, add http://localhost:3001.
CORS_ALLOW_ORIGINS=https://astro.example.in,http://localhost:3001
