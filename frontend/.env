# Frontend runtime/build configuration

# Production, recommended:
# Leave blank or unset so every API call goes to the same URL under /api.
# Example: https://astro.example.in/api/...
VITE_API_BASE_URL=

# Development proxy target used by `npm run dev`.
VITE_API_PROXY_TARGET=http://127.0.0.1:8001
VITE_DEV_HOST=0.0.0.0
VITE_DEV_PORT=3001
